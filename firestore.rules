rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'targetLanguage', 'stats', 'achievements'])
        && data.keys().size() == 6
        && data.uid is string && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email == request.auth.token.email
        && data.targetLanguage in ['English', 'Somali']
        && data.stats is map
        && data.stats.xp is int && data.stats.xp >= 0
        && data.stats.streak is int && data.stats.streak >= 0
        && data.stats.completedLessons is int && data.stats.completedLessons >= 0
        && data.stats.skillLevel in ['Beginner', 'Intermediate', 'Advanced']
        && data.achievements is list
        && data.achievements.size() <= 100;
    }

    // --- Collection Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && (
          // Action: Profile Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'targetLanguage'])) ||
          // Action: Progress Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['stats', 'achievements']))
        )
        && incoming().uid == existing().uid
        && incoming().email == existing().email;

      allow delete: if false; // Users cannot delete their accounts via client SDK for safety
    }
  }
}
